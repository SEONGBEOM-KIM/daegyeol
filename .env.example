# Public values: these are exposed to the browser when prefixed with NEXT_PUBLIC_.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
# New Supabase projects should use the publishable key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy fallback. Keep empty when using a publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets: never expose these in browser code.
OPENAI_API_KEY=

# Avoid using this in the first MVP unless a server-only admin task is explicitly needed.
SUPABASE_SERVICE_ROLE_KEY=
